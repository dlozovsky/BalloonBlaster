{
  "name": "balloon-blaster",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A browser-based 3D balloon shooting arcade game",
  "scripts": {
    "start": "npx --yes serve . -p 8080",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "npm run lint && npm test",
    "check:all": "npm run check && npm run test:e2e",
    "prepare": "simple-git-hooks",
    "test": "node --test tests/*.test.js",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "simple-git-hooks": "^2.13.1"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run check"
  }
}
